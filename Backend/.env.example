# ════════════════════════════════════════════════════════════════════
# FABIOARTS BACKEND — .env.example
# Copie para .env e ajuste os valores. NUNCA commit o .env real.
# ════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development           # development | production | test
PORT=3333                      # porta HTTP do backend

# ── Database ────────────────────────────────────────────────────────
# Postgres. Em produção (Neon/Supabase/RDS), inclua ?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fabioarts_db?schema=public

# ── JWT ─────────────────────────────────────────────────────────────
# Use strings aleatórias com 32+ caracteres em produção
# (ex: `openssl rand -hex 48` ou `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`)
JWT_SECRET=change_me_to_a_random_string_with_at_least_32_chars
JWT_EXPIRES_IN=7d              # 1h | 24h | 7d | 30d

JWT_REFRESH_SECRET=change_me_too_another_random_string_32_chars_min
JWT_REFRESH_EXPIRES_IN=30d

# ── Admin Seed ──────────────────────────────────────────────────────
# Usado por `npm run prisma:seed` para criar o admin inicial
ADMIN_EMAIL=admin@fabioarts.co
ADMIN_PASSWORD=Admin@123        # TROQUE em produção (mín. 8 chars)
ADMIN_NAME=Fabio Admin

# ── Upload ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760          # 10 MB
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# ── CORS ────────────────────────────────────────────────────────────
# Lista CSV de origens permitidas (sem trailing slash). Em produção,
# inclua os domínios do site público + admin se forem separados.
#
# Dev local (default):
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5501,http://localhost:5501,http://localhost:3000,http://localhost:5173
#
# Exemplo produção (descomente e ajuste):
# CORS_ORIGIN=https://fabioarts.co,https://www.fabioarts.co,https://admin.fabioarts.co

# ── Rate Limit ──────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000     # 15 minutos (janela global)
RATE_LIMIT_MAX_REQUESTS=100     # máx por IP por janela

# ── App URL ─────────────────────────────────────────────────────────
# Usada para montar URLs de arquivos estáticos (ex: /uploads/...)
APP_URL=http://localhost:3333
# Em produção: APP_URL=https://api.fabioarts.co

# ── Google Reviews (R9D) ────────────────────────────────────────────
# Chave da Google Places API v1. Sem chave, a rota /reviews/google
# devolve modo "manual" com os campos do admin/settings.
# Obtenha em: https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=
# TTL do cache em memória (horas). Default 12.
GOOGLE_REVIEWS_CACHE_HOURS=12
# Fallback de placeId quando admin/settings.googlePlaceId estiver vazio.
GOOGLE_PLACE_ID=
