// ============================================================
// FABIOARTS — PRISMA SCHEMA COMPLETO
// PostgreSQL + Prisma ORM
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum QuoteStatus {
  PENDING
  REPLIED
  CLOSED
  CANCELLED
}

enum ProjectCategory {
  AUTOMOTIVE
  TSHIRT
  STICKER
  BRANDING
  SOCIAL_MEDIA
  LOGO
  PACKAGING
  ILLUSTRATION
  OTHER
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum FinancialStatus {
  PAID
  PENDING
  CANCELLED
}

// ============================================================
// USER (ADMIN)
// ============================================================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

// ============================================================
// REFRESH TOKENS
// ============================================================

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id          String   @id @default(uuid())
  name        String
  company     String?
  logo        String?
  testimonial String?
  instagram   String?
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
  financialEntries FinancialEntry[]

  @@map("clients")
}

// ============================================================
// PROJECTS
// ============================================================

model Project {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  description String
  category    ProjectCategory
  thumbnail   String
  tags        String[]
  clientId    String?
  isFeatured  Boolean         @default(false)
  isPublished Boolean         @default(true)
  projectDate DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  client Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  images ProjectImage[]
  financialEntries FinancialEntry[]

  @@map("projects")
}

model ProjectImage {
  id        String   @id @default(uuid())
  url       String
  alt       String?
  order     Int      @default(0)
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_images")
}

// ============================================================
// SERVICES
// ============================================================

model Service {
  id            String   @id @default(uuid())
  name          String
  description   String
  startingPrice Float?
  image         String?
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("services")
}

// ============================================================
// QUOTES (ORÇAMENTOS)
// ============================================================

model Quote {
  id              String      @id @default(uuid())
  name            String
  email           String
  whatsapp        String
  company         String?
  projectType     String
  description     String
  estimatedBudget String?
  status          QuoteStatus @default(PENDING)
  adminNotes      String?
  repliedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  financialEntries FinancialEntry[]

  @@map("quotes")
}

// ============================================================
// SITE SETTINGS
// ============================================================

model SiteSettings {
  id          String   @id @default(uuid())
  companyName String   @default("FabioArts")
  bio         String?
  instagram   String?
  behance     String?
  linkedin    String?
  whatsapp    String?
  email       String?
  logo        String?
  banner      String?

  // ── Hero (Fase E) ───────────────────────────────────────
  heroLabel               String?
  heroTitle               String?
  heroSubtitle            String?
  heroPrimaryText         String?
  heroPrimaryUrl          String?
  heroSecondaryText       String?
  heroSecondaryUrl        String?
  heroImage               String?

  // ── Sobre (Fase E) ──────────────────────────────────────
  aboutLabel              String?
  aboutTitle              String?
  aboutText1              String?
  aboutText2              String?
  aboutImage1             String?
  aboutImage2             String?

  // ── Mentoria (Fase E) ───────────────────────────────────
  mentorshipLabel         String?
  mentorshipTitle         String?
  mentorshipSubtitle      String?
  mentorshipPrimaryText   String?
  mentorshipPrimaryUrl    String?
  mentorshipSecondaryText String?
  mentorshipSecondaryUrl  String?
  mentorshipChannelName   String?
  mentorshipOnlineCount   Int?

  // ── Processo (Fase E) ──────────────────────────────────
  processLabel            String?
  processTitle            String?
  processSubtitle         String?

  // ── Footer (Fase E) ────────────────────────────────────
  footerCopyright         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

// ============================================================
// CONTENT COLLECTIONS (Fase E)
// ============================================================

model AboutStat {
  id        String   @id @default(uuid())
  number    String
  suffix    String?
  label     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("about_stats")
}

model MentorshipFeature {
  id        String   @id @default(uuid())
  icon      String?
  text      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("mentorship_features")
}

model ProcessStep {
  id          String   @id @default(uuid())
  stepNumber  String
  title       String
  description String
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("process_steps")
}

model Course {
  id          String       @id @default(uuid())
  title       String
  category    String
  description String
  level       CourseLevel  @default(BEGINNER)
  duration    String?
  price       String?
  image       String?
  externalUrl String?
  label       String?
  isActive    Boolean      @default(true)
  isFeatured  Boolean      @default(false)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("courses")
}

model FooterColumn {
  id        String       @id @default(uuid())
  title     String
  order     Int          @default(0)
  isActive  Boolean      @default(true)
  links     FooterLink[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("footer_columns")
}

model FooterLink {
  id         String        @id @default(uuid())
  columnId   String
  column     FooterColumn  @relation(fields: [columnId], references: [id], onDelete: Cascade)
  label      String
  url        String
  isExternal Boolean       @default(false)
  order      Int           @default(0)
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("footer_links")
}

model CTAButton {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  url         String
  isExternal  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cta_buttons")
}

// ============================================================
// FINANCIAL (Fase D)
// NB: amount usa Float por enquanto (MVP). Em uma versão futura,
// migrar para Decimal para precisão monetária real.
// ============================================================

model FinancialEntry {
  id            String           @id @default(uuid())
  type          FinancialType
  amount        Float
  currency      String           @default("BRL")
  description   String
  category      String?
  status        FinancialStatus  @default(PAID)
  occurredAt    DateTime
  dueDate       DateTime?
  paymentMethod String?
  notes         String?

  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  quoteId    String?
  quote      Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("financial_entries")
}